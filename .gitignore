# Claude Code — this repo is PUBLIC. Share the reusable automation (settings.json =
# permissions + hooks, and the skills); keep the secret/infra-bearing local file out.
# Whitelist style: everything under .claude/ is ignored UNLESS explicitly un-ignored,
# so any new local file (caches, secrets) stays out by default until you opt it in.
.claude/*
!.claude/settings.json
!.claude/skills/
.claude/settings.local.json

# Local-only Arbeitsartefakte — dieses Repo ist PUBLIC. Der Audit-Report und sein Ledger
# enumerieren noch UNGEFIXTE Funde (inkl. ausnutzbarer Sicherheitslücken mit Datei:Zeile);
# das Release-Ledger enthält interne Homelab-Infra. Bleiben lokal, nicht ins öffentliche Repo.
/fabelreport.md
/tasks/audit-fixes.md
/tasks/test-infra-capstone-release.md

# crabbox local failure-capture bundles (0700, not fully redacted — never commit)
.crabbox/
# crabbox auto-debug artifacts pulled off the box (screenshots/logs) + desktop XDG
.crabbox-out/
.dt-xdg/

# Agent build output produced at the repo root by apps/agent/build-deb.sh /
# build-rpm.sh (and the frpc binary staged there by the crabbox agent role).
/frpc
/build-deb/
/build-rpm/
*.swp
*.swo
*~

# Python virtual environments
venv/
.venv/
__pycache__/
*.pyc

# Docker dev override
docker-compose.override.yml

# Env files
.env
.env.*
!.env.example
!.env.template

# Server-Datendverzeichnis (bind mount statt Docker-Volume)
/data/

# Agent-Paket-Repo (apt/rpm): vom Updater befuellter bind mount, kein Quellcode
/repo/

# Build-Artefakte
build-deb/
*.deb
*.rpm

# TLS-Zertifikate (auto-generiert oder eigene)
/certs/

# Schluessel-Container — enthalten private Schluessel, NIE committen
# (z.B. der Browser-mTLS-Export adminhelper-browser.p12 aus dem Desktop-Client)
*.p12
*.pfx

# Backup-Tarballs (enthalten Secrets: DB-Dumps, .env, verschluesselter Root-Key)
/backups/

# Playwright
/apps/web/test-results/
/apps/web/playwright-report/
/apps/web/playwright/.cache/

# pytest cache (lokal)
.pytest_cache/

# Lokale Dev-Env-Helferdatei (Toolchain-PATH + Test-DB-URL)
/.devenv.sh
